<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ui_background"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        android:background="@color/ui_header_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="16dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="@string/content_desc_icon"
            android:focusable="true"
            android:padding="12dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/ui_header_text" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="?attr/actionBarSize"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:text="@string/header_edge_lighting"
            android:textColor="@color/ui_header_text"
            android:textSize="20sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <!-- Live Preview -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="360dp"
                android:clipToOutline="true">

                <FrameLayout
                    android:id="@+id/preview_phone_frame"
                    android:layout_width="176dp"
                    android:layout_height="320dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_edge_lighting_phone_preview"
                    android:clipToOutline="true">

                    <com.fan.edgex.overlay.EdgeLightingView
                        android:id="@+id/preview_lighting_view"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <View
                        android:layout_width="24dp"
                        android:layout_height="3dp"
                        android:layout_gravity="top|center_horizontal"
                        android:layout_marginTop="11dp"
                        android:background="@drawable/bg_edge_lighting_phone_speaker" />

                    <LinearLayout
                        android:layout_width="144dp"
                        android:layout_height="48dp"
                        android:layout_gravity="top|center_horizontal"
                        android:layout_marginTop="30dp"
                        android:background="@drawable/bg_edge_lighting_notification_preview"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp">

                        <View
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:background="@drawable/bg_edge_lighting_notification_dot" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:ellipsize="end"
                                android:singleLine="true"
                                android:text="@string/edge_lighting_preview_notification_title"
                                android:textColor="#E6000000"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:ellipsize="end"
                                android:singleLine="true"
                                android:text="@string/edge_lighting_preview_notification_body"
                                android:textColor="#99000000"
                                android:textSize="8sp" />
                        </LinearLayout>
                    </LinearLayout>
                </FrameLayout>

                <TextView
                    android:id="@+id/preview_effect_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="14dp"
                    android:layout_marginBottom="12dp"
                    android:textColor="#AAFFFFFF"
                    android:textSize="13sp" />
            </FrameLayout>

            <!-- Effect Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/edge_lighting_effect"
                android:textColor="@color/ui_text_secondary"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/effect_chips_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="2dp" />
            </HorizontalScrollView>

            <!-- General Settings Card -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/edge_lighting_section_general"
                android:textColor="@color/ui_text_secondary"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08" />

            <LinearLayout
                android:id="@+id/card_general"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical">

                <!-- Enable Edge Lighting row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/edge_lighting_enabled"
                        android:textColor="@color/ui_text_primary"
                        android:textSize="15sp" />

                    <Switch
                        android:id="@+id/switch_edge_lighting_enabled"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="16dp"
                    android:background="@color/ui_divider" />

                <!-- Auto Color row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:minHeight="56dp"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/edge_lighting_auto_color"
                            android:textColor="@color/ui_text_primary"
                            android:textSize="15sp" />
                    </LinearLayout>

                    <Switch
                        android:id="@+id/switch_auto_color"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="16dp"
                    android:background="@color/ui_divider" />

                <!-- Notification Access row -->
                <LinearLayout
                    android:id="@+id/item_notification_access"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="56dp"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/edge_lighting_notification_access_title"
                            android:textColor="@color/ui_text_primary"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/text_notification_access_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@string/content_desc_icon"
                        android:src="@drawable/ic_expand_more"
                        android:rotation="270"
                        app:tint="@color/ui_text_secondary" />
                </LinearLayout>
            </LinearLayout>

            <!-- Color Card -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/edge_lighting_section_color"
                android:textColor="@color/ui_text_secondary"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/preview_edge_lighting_color"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_theme_swatch" />

                    <TextView
                        android:id="@+id/text_edge_lighting_color_hex"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:textColor="@color/ui_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btn_edge_lighting_apply_color"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_save" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/edit_edge_lighting_red"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_edit_text"
                        android:ems="3"
                        android:gravity="center"
                        android:hint="@string/theme_red"
                        android:inputType="number"
                        android:maxLength="3"
                        android:padding="10dp"
                        android:textColor="@color/ui_text_primary"
                        android:textColorHint="@color/ui_text_secondary" />

                    <EditText
                        android:id="@+id/edit_edge_lighting_green"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_edit_text"
                        android:ems="3"
                        android:gravity="center"
                        android:hint="@string/theme_green"
                        android:inputType="number"
                        android:maxLength="3"
                        android:padding="10dp"
                        android:textColor="@color/ui_text_primary"
                        android:textColorHint="@color/ui_text_secondary" />

                    <EditText
                        android:id="@+id/edit_edge_lighting_blue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_edit_text"
                        android:ems="3"
                        android:gravity="center"
                        android:hint="@string/theme_blue"
                        android:inputType="number"
                        android:maxLength="3"
                        android:padding="10dp"
                        android:textColor="@color/ui_text_primary"
                        android:textColorHint="@color/ui_text_secondary" />
                </LinearLayout>
            </LinearLayout>

            <!-- Appearance Card -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/edge_lighting_section_appearance"
                android:textColor="@color/ui_text_secondary"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/edge_lighting_label_width"
                        android:textColor="@color/ui_text_primary"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/text_edge_lighting_width_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/ui_text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seek_edge_lighting_width"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:background="@color/ui_divider" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/edge_lighting_label_opacity"
                        android:textColor="@color/ui_text_primary"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/text_edge_lighting_alpha_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/ui_text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seek_edge_lighting_alpha"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- Timing Card -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/edge_lighting_section_timing"
                android:textColor="@color/ui_text_secondary"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/edge_lighting_label_duration"
                        android:textColor="@color/ui_text_primary"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/text_edge_lighting_duration_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/ui_text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seek_edge_lighting_duration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- Apps Card -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/edge_lighting_section_apps"
                android:textColor="@color/ui_text_secondary"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08" />

            <LinearLayout
                android:id="@+id/item_edge_lighting_apps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_card"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="56dp"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/edge_lighting_app_filter"
                        android:textColor="@color/ui_text_primary"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/text_edge_lighting_app_summary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/ui_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@string/content_desc_icon"
                    android:src="@drawable/ic_expand_more"
                    android:rotation="270"
                    app:tint="@color/ui_text_secondary" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
